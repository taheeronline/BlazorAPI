@page "/movies"
@rendermode InteractiveServer
@inject iMovieService MovieService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Movie List</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-film"></i> Movie Directory</h2>
        <AuthorizeView>
            <Authorized>
                <button class="btn btn-primary shadow-sm" @onclick="AddMovie">
                    + Add Movie
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body py-3">
            <div class="row gx-2">
                <div class="col-md-3">
                    <select class="form-select" @bind="searchType">
                        <option value="Title">Search by Title</option>
                        <option value="Director">Search by Director</option>
                        <option value="Genre">Search by Genre</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <input type="text" class="form-control" placeholder="Enter search term..." @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-secondary w-100" @onclick="SearchMovies">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearSearch">
                        Clear
                    </button>
                </div>
            </div>
        </div>
    </div>
    @if (movies == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!movies.Any())
    {
        <div class="alert alert-info shadow-sm">
            No movies found matching your criteria.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Director</th>
                                <th>Genre</th>
                                <th>Release Date</th>
                                <th>Rating</th>
                                <th class="text-center" style="width: 160px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var movie in movies)
                            {
                                <tr class="align-middle">
                                    <td class="fw-bold text-primary">@movie.Title</td>
                                    <td>@movie.Director</td>
                                    <td>
                                        <span class="badge bg-secondary">@movie.Genre</span>
                                    </td>
                                    <td>@movie.ReleaseDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <span class="text-warning fw-bold">★</span> @movie.Rating.ToString("0.0") / 10
                                    </td>
                                    <td class="text-center">
                                        <AuthorizeView>
                                            <Authorized>
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => EditMovie(movie)">
                                                        Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMovie(movie)">
                                                        Delete
                                                    </button>
                                                </div>
                                            </Authorized>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
<br />
<br />

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private IEnumerable<MovieDTO>? movies;
    private string searchType = "Title";
    private string searchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadMovies();
    }

    private async Task LoadMovies()
    {
        movies = await MovieService.GetAll();
    }

    private async Task SearchMovies()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadMovies();
            return;
        }

        movies = null;

        try
        {
            switch (searchType)
            {
                case "Director":
                    movies = await MovieService.GetByDirector(searchTerm);
                    break;
                case "Genre":
                    movies = await MovieService.GetByGenre(searchTerm);
                    break;
                case "Title":
                default:
                    movies = await MovieService.GetByTitle(searchTerm);
                    break;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search error: {ex.Message}");
            movies = Enumerable.Empty<MovieDTO>();
        }
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        movies = null;
        await LoadMovies();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchMovies();
        }
    }

    private void AddMovie()
    {
        NavigationManager.NavigateTo("/movies/add");
    }

    private void EditMovie(MovieDTO movie)
    {
        NavigationManager.NavigateTo($"/movies/edit/{movie.Id}");
    }

    private async Task DeleteMovie(MovieDTO movie)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you absolutely sure you want to delete '{movie.Title}'?");

        if (confirmed)
        {
            try
            {
                int modifiedById = 0;

                // Extract the logged-in user's ID
                if (AuthStateTask != null)
                {
                    var authState = await AuthStateTask;
                    var user = authState.User;

                    if (user.Identity is not null && user.Identity.IsAuthenticated)
                    {
                        var userIdString = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                        int.TryParse(userIdString, out modifiedById);
                    }
                }

                // Pass both the movie ID and the user ID to the service
                await MovieService.DeleteMovie(movie.Id, modifiedById);

                if (!string.IsNullOrWhiteSpace(searchTerm))
                {
                    await SearchMovies();
                }
                else
                {
                    await LoadMovies();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting movie: {ex.Message}");
            }
        }
    }
}