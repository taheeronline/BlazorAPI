@page "/"
@using MovieManager.Web.Services
@using MovieManager.Web.DTOs
@inject iMovieApiService MovieService
@inject IJSRuntime JS 
@rendermode InteractiveServer

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="text-primary fw-bold mb-0"><i class="bi bi-film me-2"></i>Cinema Database</h2>
            <p class="text-muted small mt-1">Manage movie catalog, ratings, and classifications</p>
        </div>
        <button class="btn btn-primary shadow-sm" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg me-1"></i> Add Record
        </button>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty"></button>
        </div>
    }

    <!-- Advanced Search Toolbar -->
    <div class="card shadow-sm mb-4 border-0 bg-light">
        <div class="card-body">
            <form @onsubmit="ExecuteSearch" class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label text-muted small fw-bold">Search Criteria</label>
                    <select class="form-select" @bind="SearchCriteria">
                        <option value="Title">By Title</option>
                        <option value="Director">By Director</option>
                        <option value="Genre">By Genre</option>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label text-muted small fw-bold">Query Parameter</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control" placeholder="Enter search term..." @bind="SearchTerm" />
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dark flex-grow-1">Search</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="ClearSearch">Clear</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Dynamic Data Grid -->
    @if (IsLoading)
    {
        <div class="text-center my-5 p-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Fetching matrix...</span>
            </div>
            <p class="mt-3 text-muted">Synchronizing with central database...</p>
        </div>
    }
    else if (Movies == null || !Movies.Any())
    {
        <div class="alert alert-secondary shadow-sm text-center py-5 border-0" role="alert">
            <i class="bi bi-inbox fs-1 d-block mb-3 text-muted"></i>
            <h5 class="text-dark">No Records Found</h5>
            <p class="text-muted mb-0">The query returned zero matches or the database is currently empty.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>Director</th>
                            <th>Genre</th>
                            <th>Release Date</th>
                            <th>Rating</th>
                            <th>Last Modified</th>
                            <th class="text-end px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var movie in Movies)
                        {
                            <tr>
                                <td class="fw-bold text-dark">@movie.Title</td>
                                <td>@movie.Director</td>
                                <td><span class="badge rounded-pill bg-info text-dark border">@movie.Genre</span></td>
                                <td>@movie.ReleaseDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-star-fill text-warning me-1 small"></i>
                                        <span class="fw-bold">@movie.Rating.ToString("0.0")</span>
                                        <span class="text-muted small ms-1">/ 10</span>
                                    </div>
                                </td>
                                <td class="text-muted small">
                                    <time class="local-time" datetime="@movie.LastModified.ToString("yyyy-MM-ddTHH:mm:ssZ")">
                                        @movie.LastModified.ToString("g") UTC
                                    </time>
                                </td>
                                <td class="text-end px-4">
                                    <div class="btn-group btn-group-sm shadow-sm">
                                        <button class="btn btn-outline-primary" @onclick="() => OpenEditModal(movie)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(movie)">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Unified Editor Modal (Create/Update) -->
@if (ShowModal)
{
    <div class="modal fade show d-block" style="background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-dark text-white border-bottom-0 py-3">
                    <h5 class="modal-title fw-bold">
                        <i class="bi @(IsEditMode ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                        @(IsEditMode ? "Update Master Record" : "Register New Release")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>

                <EditForm Model="EditorModel" OnValidSubmit="SaveRecordAsync">
                    <DataAnnotationsValidator />
                    <div class="modal-body p-4 bg-light">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Title</label>
                                <InputText class="form-control form-control-lg" @bind-Value="EditorModel.Title" placeholder="e.g., Inception" />
                                <ValidationMessage For="@(() => EditorModel.Title)" class="text-danger small mt-1" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Director</label>
                                <InputText class="form-control" @bind-Value="EditorModel.Director" />
                                <ValidationMessage For="@(() => EditorModel.Director)" class="text-danger small mt-1" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Genre</label>
                                <InputText class="form-control" @bind-Value="EditorModel.Genre" />
                                <ValidationMessage For="@(() => EditorModel.Genre)" class="text-danger small mt-1" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Release Date</label>
                                <InputDate class="form-control" @bind-Value="EditorModel.ReleaseDate" TValue="DateTimeOffset" />
                                <ValidationMessage For="@(() => EditorModel.ReleaseDate)" class="text-danger small mt-1" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Global Rating (0-10)</label>
                                <InputNumber class="form-control" @bind-Value="EditorModel.Rating" step="0.1" min="0" max="10" />
                                <ValidationMessage For="@(() => EditorModel.Rating)" class="text-danger small mt-1" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-white border-top-0 py-3">
                        <button type="button" class="btn btn-light border px-4" @onclick="CloseModal">Discard Changes</button>
                        <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm" disabled="@IsProcessing">
                            @if (IsProcessing)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Processing...</span>
                            }
                            else
                            {
                                <span>Commit to Database</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (ShowDeleteModal)
{
    <div class="modal fade show d-block" style="background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-body text-center p-4">
                    <i class="bi bi-exclamation-circle text-danger display-4 mb-3 d-block"></i>
                    <h5 class="fw-bold mb-3">Confirm Deletion</h5>
                    <p class="text-muted mb-4">Are you absolutely sure you want to permanently delete <strong>@MovieToDelete?.Title</strong>? This action cannot be reversed.</p>
                    <div class="d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-light border w-50" @onclick="() => ShowDeleteModal = false">Cancel</button>
                        <button type="button" class="btn btn-danger w-50" @onclick="ExecuteDeleteAsync">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<MovieDTO>? Movies;
    private bool IsLoading = true;
    private bool IsProcessing = false;
    private string ErrorMessage = string.Empty;

    // Search State
    private string SearchCriteria { get; set; } = "Title";
    private string SearchTerm { get; set; } = string.Empty;

    // Modal State
    private bool ShowModal = false;
    private bool ShowDeleteModal = false;
    private bool IsEditMode = false;
    private Guid TargetId;
    private MovieDTO? MovieToDelete;

    // Editor Model utilizes a unified class for form binding, mapped to exact DTOs on submission
    private class MovieEditorModel
    {
        public string Title { get; set; } = string.Empty;
        public string Director { get; set; } = string.Empty;
        public string Genre { get; set; } = string.Empty;
        public DateTimeOffset ReleaseDate { get; set; } = DateTimeOffset.Now;
        public double Rating { get; set; }
    }

    private MovieEditorModel EditorModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadGridAsync();
    }

    // ADD THIS METHOD: It runs every time Blazor updates the HTML
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Only run the script if there are actually movies on the screen
        if (Movies != null && Movies.Any() && !IsLoading)
        {
            try
            {
                await JS.InvokeVoidAsync("formatLocalTimes");
            }
            catch (JSDisconnectedException)
            {
                // Ignored: Sometimes thrown if the user navigates away before JS finishes
            }
        }
    }

    private async Task LoadGridAsync()
    {
        IsLoading = true;
        ErrorMessage = string.Empty;
        StateHasChanged();

        Movies = await MovieService.GetAllMoviesAsync();

        IsLoading = false;
    }

    private async Task ExecuteSearch()
    {
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            await LoadGridAsync();
            return;
        }

        IsLoading = true;
        ErrorMessage = string.Empty;

        Movies = SearchCriteria switch
        {
            "Director" => await MovieService.SearchByDirectorAsync(SearchTerm),
            "Genre" => await MovieService.SearchByGenreAsync(SearchTerm),
            _ => await MovieService.SearchByTitleAsync(SearchTerm) // Default to Title
        };

        IsLoading = false;
    }

    private async Task ClearSearch()
    {
        SearchTerm = string.Empty;
        await LoadGridAsync();
    }

    private void OpenCreateModal()
    {
        IsEditMode = false;
        EditorModel = new MovieEditorModel(); // Resets to defaults
        ShowModal = true;
    }

    private void OpenEditModal(MovieDTO movie)
    {
        IsEditMode = true;
        TargetId = movie.Id;

        // Isolate state in editor model to prevent live grid modifications before commit
        EditorModel = new MovieEditorModel
        {
            Title = movie.Title,
            Director = movie.Director,
            Genre = movie.Genre,
            ReleaseDate = movie.ReleaseDate,
            Rating = movie.Rating
        };
        ShowModal = true;
    }

    private void CloseModal()
    {
        ShowModal = false;
        IsProcessing = false;
    }

    private void ConfirmDelete(MovieDTO movie)
    {
        MovieToDelete = movie;
        ShowDeleteModal = true;
    }

    private async Task SaveRecordAsync()
    {
        IsProcessing = true;
        ErrorMessage = string.Empty;

        try
        {
            if (IsEditMode)
            {
                var updateDto = new UpdateMovieDTO
                {
                    Title = EditorModel.Title,
                    Director = EditorModel.Director,
                    Genre = EditorModel.Genre,
                    ReleaseDate = EditorModel.ReleaseDate,
                    Rating = EditorModel.Rating
                };

                var result = await MovieService.UpdateMovieAsync(TargetId, updateDto);
                if (result == null)
                {
                    ErrorMessage = "Failed to update the record. Verify the API connection.";
                    IsProcessing = false;
                    return;
                }
            }
            else
            {
                var createDto = new CreateMovieDTO
                {
                    Title = EditorModel.Title,
                    Director = EditorModel.Director,
                    Genre = EditorModel.Genre,
                    ReleaseDate = EditorModel.ReleaseDate,
                    Rating = EditorModel.Rating
                };

                var result = await MovieService.CreateMovieAsync(createDto);
                if (result == null)
                {
                    ErrorMessage = "Failed to create the record. Verify the API connection.";
                    IsProcessing = false;
                    return;
                }
            }

            CloseModal();
            await ExecuteSearch(); // Reload current view keeping search criteria if applied
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private async Task ExecuteDeleteAsync()
    {
        if (MovieToDelete == null) return;

        ShowDeleteModal = false;
        IsLoading = true;

        var success = await MovieService.DeleteMovieAsync(MovieToDelete.Id);
        if (!success)
        {
            ErrorMessage = "Deletion failed. Ensure the record hasn't been modified or removed externally.";
        }

        MovieToDelete = null;
        await ExecuteSearch();
    }
}