@page "/users"
@rendermode InteractiveServer
@inject BlazorAPI.BlazorUI.Services.Interface.IUserService UserService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>User Directory</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-people"></i> User Management</h2>
            <p class="text-muted">Manage system access and user profiles.</p>
        </div>
        <div>
            <AuthorizeView>
                <Authorized>
                    <a href="/register" class="btn btn-primary shadow-sm fw-bold">
                        <i class="bi bi-person-plus"></i> Add New User
                    </a>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger shadow-sm">@errorMessage</div>
    }
    else if (pagedResult == null || !pagedResult.Items.Any())
    {
        <div class="p-5 text-center text-muted border shadow-sm bg-light">
            <i class="bi bi-inbox fs-1"></i>
            <p class="mt-2">No users found in the system.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">Name</th>
                                <th>Username</th>
                                <th>Email</th>
                                <AuthorizeView>
                                    <Authorized>

                                        <th class="text-center">Actions</th>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in pagedResult.Items)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@user.Name</td>
                                    <td><span class="badge bg-secondary">@user.UserName</span></td>
                                    <td><a href="mailto:@user.Email" class="text-decoration-none">@user.Email</a></td>
                                    <AuthorizeView>
                                        <Authorized>
                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <button class="btn btn-outline-primary" @onclick="() => EditUser(user.Id)">
                                                        <i class="bi bi-pencil"></i> Edit
                                                    </button>
                                                    <button class="btn btn-outline-danger" @onclick="() => DeleteUser(user)">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </Authorized>
                                    </AuthorizeView>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
                <span class="text-muted fw-bold">
                    Page @pagedResult.CurrentPage of @pagedResult.TotalPages
                </span>
                <div class="btn-group shadow-sm">
                    <button class="btn btn-outline-primary" disabled="@(!pagedResult.HasPrevious)" @onclick="GoToPreviousPage">Previous</button>
                    <button class="btn btn-outline-primary" disabled="@(!pagedResult.HasNext)" @onclick="GoToNextPage">Next</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private PagedResult<UserDTO>? pagedResult;
    private bool isLoading = true;
    private string? errorMessage;
    private int currentPage = 1;
    private int pageSize = 3;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            pagedResult = await UserService.GetAllAsync(currentPage, pageSize);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
            errorMessage = "Failed to load user list.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GoToPreviousPage()
    {
        if (pagedResult?.HasPrevious == true)
        {
            currentPage--;
            await LoadUsersAsync();
        }
    }

    private async Task GoToNextPage()
    {
        if (pagedResult?.HasNext == true)
        {
            currentPage++;
            await LoadUsersAsync();
        }
    }

    private void EditUser(int id)
    {
        NavigationManager.NavigateTo($"/users/edit/{id}");
    }

    private async Task DeleteUser(UserDTO user)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to permanently delete '{user.Name}'?");

        if (confirmed)
        {
            try
            {
                int modifiedById = 0;

                if (AuthStateTask != null)
                {
                    var authState = await AuthStateTask;
                    var userIdString = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                    int.TryParse(userIdString, out modifiedById);
                }

                await UserService.DeleteUserAsync(user.Id, modifiedById);
                await LoadUsersAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting user: {ex.Message}");
                errorMessage = "Failed to delete user.";
            }
        }
    }
}