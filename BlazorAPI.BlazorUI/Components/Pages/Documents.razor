@page "/documents"
@rendermode InteractiveServer
@using System.Security.Claims
@using BlazorAPI.BlazorUI.DTOs.DocumentDTO
@inject BlazorAPI.BlazorUI.Services.Interface.IDocumentService DocumentService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Document List</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-file-earmark-text"></i> Document Library</h2>
        <AuthorizeView>
            <Authorized>
                <button class="btn btn-primary shadow-sm" @onclick="AddDocument">
                    + Add Document
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body py-3">
            <div class="row gx-2">
                <div class="col-md-3">
                    <select class="form-select" @bind="searchType">
                        <option value="Name">Search by Name</option>
                        <option value="FileName">Search by File Name</option>
                        <option value="ContentType">Search by Content Type</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <input type="text" class="form-control" placeholder="Enter search term..." @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-secondary w-100" @onclick="ExecuteSearch">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearSearch">
                        Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger shadow-sm">
            @errorMessage
        </div>
    }
    else if (paginatedDocuments == null || !paginatedDocuments.Any())
    {
        <div class="alert alert-info shadow-sm">
            No documents found matching your criteria.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 25%;">Name</th>
                                <th style="width: 30%;">File Name</th>
                                <th style="width: 15%;">Content Type</th>
                                <th style="width: 10%;">Size</th>
                                <AuthorizeView>
                                    <Authorized>
                                        <th class="text-center" style="width: 20%;">Actions</th>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var document in paginatedDocuments)
                            {
                                <tr class="align-middle">
                                    <td class="fw-bold text-primary">@document.Name</td>
                                    <td>
                                        <span class="text-truncate d-inline-block" style="max-width: 250px;" title="@document.FileName">
                                            @document.FileName
                                        </span>
                                    </td>
                                    <td>@document.ContentType</td>
                                    <td>@FormatFileSize(document.FileSize)</td>
                                    <AuthorizeView>
                                        <Authorized>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-sm btn-outline-info" @onclick="() => DownloadDocument(document.Id)">
                                                        Download
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => EditDocument(document)">
                                                        Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDocument(document)">
                                                        Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </Authorized>
                                    </AuthorizeView>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
                <span class="text-muted fw-bold">
                    Page @currentPage of @totalPages
                    <span class="fw-normal ms-2">(Total: @totalCount records)</span>
                </span>
                <div class="btn-group shadow-sm">
                    <button class="btn btn-outline-primary" disabled="@(!HasPrevious)" @onclick="GoToPreviousPage">
                        Previous
                    </button>
                    <button class="btn btn-outline-primary" disabled="@(!HasNext)" @onclick="GoToNextPage">
                        Next
                    </button>
                </div>
            </div>
        </div>
    }
</div>
<br />
<br />

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private IEnumerable<DocumentMetadataDto>? allDocuments;
    private IEnumerable<DocumentMetadataDto>? paginatedDocuments;

    private string searchType = "Name";
    private string searchTerm = string.Empty;
    private bool isLoading = true;
    private string? errorMessage;

    // Pagination State
    private int currentPage = 1;
    private int pageSize = 10; // Adjusted for lists of files
    private int totalCount = 0;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);
    private bool HasPrevious => currentPage > 1;
    private bool HasNext => currentPage < totalPages;

    protected override async Task OnInitializedAsync()
    {
        await FetchData();
    }

    private void ExecuteSearch()
    {
        currentPage = 1;
        ApplyFiltersAndPagination();
    }

    private async Task FetchData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Fetch everything once since our endpoint returns IEnumerable
            allDocuments = await DocumentService.GetAllMetadataAsync();
            ApplyFiltersAndPagination();
        }
        catch (HttpRequestException ex)
        {
            Console.WriteLine($"Network or API error: {ex.Message}");
            errorMessage = "Failed to communicate with the server. Please try again.";
            allDocuments = Array.Empty<DocumentMetadataDto>();
            paginatedDocuments = Array.Empty<DocumentMetadataDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Unexpected error: {ex.Message}");
            errorMessage = "An unexpected error occurred while loading data.";
            allDocuments = Array.Empty<DocumentMetadataDto>();
            paginatedDocuments = Array.Empty<DocumentMetadataDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFiltersAndPagination()
    {
        if (allDocuments == null) return;

        var query = allDocuments.AsQueryable();

        // Apply Search
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.ToLower();
            query = searchType switch
            {
                "FileName" => query.Where(d => d.FileName != null && d.FileName.ToLower().Contains(term)),
                "ContentType" => query.Where(d => d.ContentType != null && d.ContentType.ToLower().Contains(term)),
                "Name" or _ => query.Where(d => d.Name != null && d.Name.ToLower().Contains(term))
            };
        }

        // Apply Pagination
        totalCount = query.Count();

        // Safety check if search reduces page count below current page
        if (currentPage > totalPages && totalPages > 0)
        {
            currentPage = totalPages;
        }

        paginatedDocuments = query
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
        currentPage = 1;
        ApplyFiltersAndPagination();
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            ExecuteSearch();
        }
    }

    // --- Pagination Navigation ---

    private void GoToPreviousPage()
    {
        if (HasPrevious)
        {
            currentPage--;
            ApplyFiltersAndPagination();
        }
    }

    private void GoToNextPage()
    {
        if (HasNext)
        {
            currentPage++;
            ApplyFiltersAndPagination();
        }
    }

    // --- Actions ---

    private void AddDocument()
    {
        NavigationManager.NavigateTo("/documents/add");
    }

    private void EditDocument(DocumentMetadataDto document)
    {
        NavigationManager.NavigateTo($"/documents/edit/{document.Id}");
    }

    private void DownloadDocument(int documentId)
    {
        // Typically handled by navigating to an endpoint or triggering JS download
        NavigationManager.NavigateTo($"/api/documents/{documentId}/download", forceLoad: true);
    }

    private async Task DeleteDocument(DocumentMetadataDto document)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you absolutely sure you want to delete '{document.Name}'?");

        if (confirmed)
        {
            try
            {
                int modifiedById = 0;

                if (AuthStateTask != null)
                {
                    var authState = await AuthStateTask;
                    var user = authState.User;

                    if (user.Identity is not null && user.Identity.IsAuthenticated)
                    {
                        var userIdString = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                        int.TryParse(userIdString, out modifiedById);
                    }
                }

                await DocumentService.DeleteDocumentAsync(document.Id, modifiedById);

                // Reload data from server
                await FetchData();
            }
            catch (HttpRequestException ex)
            {
                Console.WriteLine($"API Error deleting document: {ex.Message}");
                errorMessage = "Failed to delete the document. Ensure you have the right permissions.";
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting document: {ex.Message}");
                errorMessage = "An unexpected error occurred during deletion.";
            }
        }
    }

    // --- Helpers ---
    private string FormatFileSize(long bytes)
    {
        string[] suffixes = { "B", "KB", "MB", "GB", "TB", "PB" };
        int counter = 0;
        decimal number = (decimal)bytes;

        while (Math.Round(number / 1024) >= 1)
        {
            number /= 1024;
            counter++;
        }

        return string.Format("{0:n1} {1}", number, suffixes[counter]);
    }
}