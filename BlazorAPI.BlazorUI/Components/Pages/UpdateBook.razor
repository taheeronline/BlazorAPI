@page "/books/edit/{Id:int}"
@rendermode InteractiveServer
@inject IBookService BookService
@inject NavigationManager NavigationManager

<PageTitle>Edit Book</PageTitle>

<div class="container-fluid mt-4">
    <div class="mb-4">
        <h2><i class="bi bi-pencil-square"></i> Edit Book</h2>
        <p class="text-muted">Update the details for this book below.</p>
    </div>

    @if (editBook == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0" style="max-width: 800px;">
            <div class="card-body p-4">

                <EditForm Model="editBook" OnValidSubmit="HandleValidSubmit" FormName="EditBookForm">
                    <DataAnnotationsValidator />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="title" class="form-label fw-bold">Title</label>
                            <InputText id="title" class="form-control" @bind-Value="editBook.Title" />
                            <ValidationMessage For="() => editBook.Title" class="text-danger small" />
                        </div>

                        <div class="col-md-6">
                            <label for="description" class="form-label fw-bold">Description</label>
                            <InputText id="description" class="form-control" @bind-Value="editBook.Description" />
                            <ValidationMessage For="() => editBook.Description" class="text-danger small" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="author" class="form-label fw-bold">Author</label>
                            <InputText id="author" class="form-control" @bind-Value="editBook.Author" />
                            <ValidationMessage For="() => editBook.Author" class="text-danger small" />
                        </div>

                        <div class="col-md-6">
                            <label for="publisher" class="form-label fw-bold">Publisher</label>
                            <InputText id="publisher" class="form-control" @bind-Value="editBook.Publisher" />
                            <ValidationMessage For="() => editBook.Publisher" class="text-danger small" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label for="price" class="form-label fw-bold">Price</label>
                            <InputNumber id="price" class="form-control" @bind-Value="editBook.Price" step="0.01" min="0" />
                            <ValidationMessage For="() => editBook.Price" class="text-danger small" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">
                            <i class="bi bi-save"></i> Update Book
                        </button>
                        <button type="button" class="btn btn-outline-secondary px-4" @onclick="NavigateBack">
                            Cancel
                        </button>
                    </div>
                </EditForm>

            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private UpdateBookDTO? editBook;

    protected override async Task OnInitializedAsync()
    {
        var existingBook = await BookService.GetByIdAsync(Id);

        if (existingBook != null)
        {
            editBook = new UpdateBookDTO   
            {
                Title = existingBook.Title,
                Description = existingBook.Description,
                Author = existingBook.Author,
                Publisher = existingBook.Publisher,
                Price = existingBook.Price
            };
        }
        else
        {
            NavigationManager.NavigateTo("/books");
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (editBook != null && AuthStateTask != null)
            {
                var authState = await AuthStateTask;
                var user = authState.User;

                if (user.Identity is not null && user.Identity.IsAuthenticated)
                {
                    var userIdString = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

                    if (int.TryParse(userIdString, out int userId))
                    {
                        editBook.ModifiedBy = userId;
                    }
                }

                await BookService.UpdateBookAsync(Id, editBook);
                NavigationManager.NavigateTo("/books");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating book: {ex.Message}");
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/books");
    }
}