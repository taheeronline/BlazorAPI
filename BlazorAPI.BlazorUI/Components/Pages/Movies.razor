@page "/movies"
@rendermode InteractiveServer
@inject BlazorAPI.BlazorUI.Services.Interface.IMovieService MovieService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Movie List</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-film"></i> Movie Directory</h2>
        <AuthorizeView>
            <Authorized>
                <button class="btn btn-primary shadow-sm" @onclick="AddMovie">
                    + Add Movie
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body py-3">
            <div class="row gx-2">
                <div class="col-md-3">
                    <select class="form-select" @bind="searchType">
                        <option value="Title">Search by Title</option>
                        <option value="Director">Search by Director</option>
                        <option value="Genre">Search by Genre</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <input type="text" class="form-control" placeholder="Enter search term..." @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-secondary w-100" @onclick="ExecuteSearch">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearSearch">
                        Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger shadow-sm">
            @errorMessage
        </div>
    }
    else if (pagedResult == null || !pagedResult.Items.Any())
    {
        <div class="alert alert-info shadow-sm">
            No movies found matching your criteria.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 28%;">Title</th>
                                <th style="width: 20%;">Director</th>
                                <th style="width: 15%;">Genre</th>
                                <th style="width: 15%;">Release Date</th>
                                <th style="width: 10%;">Rating</th>
                                <AuthorizeView>
                                    <Authorized>
                                        <th class="text-center" style="width: 12%;">Actions</th>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var movie in pagedResult.Items)
                            {
                                <tr class="align-middle">
                                    <td class="fw-bold text-primary">@movie.Title</td>
                                    <td>@movie.Director</td>
                                    <td>
                                        <span class="badge bg-secondary">@movie.Genre</span>
                                    </td>
                                    <td>@movie.ReleaseDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <span class="text-warning fw-bold">★</span> @movie.Rating.ToString("0.0") / 10
                                    </td>
                                    <AuthorizeView>
                                        <Authorized>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => EditMovie(movie)">
                                                        Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMovie(movie)">
                                                        Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </Authorized>
                                    </AuthorizeView>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
                <span class="text-muted fw-bold">
                    Page @pagedResult.CurrentPage of @pagedResult.TotalPages
                    <span class="fw-normal ms-2">(Total: @pagedResult.TotalCount records)</span>
                </span>
                <div class="btn-group shadow-sm">
                    <button class="btn btn-outline-primary" disabled="@(!pagedResult.HasPrevious)" @onclick="GoToPreviousPage">
                        Previous
                    </button>
                    <button class="btn btn-outline-primary" disabled="@(!pagedResult.HasNext)" @onclick="GoToNextPage">
                        Next
                    </button>
                </div>
            </div>
        </div>
    }
</div>
<br />
<br />

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private PagedResult<MovieDTO>? pagedResult;
    private string searchType = "Title";
    private string searchTerm = string.Empty;
    private bool isLoading = true;
    private string? errorMessage;

    // Pagination State
    private int currentPage = 1;
    private int pageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        await LoadMovies();
    }

    private async Task LoadMovies()
    {
        await FetchData();
    }

    private async Task ExecuteSearch()
    {
        currentPage = 1;
        await FetchData();
    }

    private async Task FetchData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            if (string.IsNullOrWhiteSpace(searchTerm))
            {
                pagedResult = await MovieService.GetAllAsync(currentPage, pageSize);
            }
            else
            {
                switch (searchType)
                {
                    case "Director":
                        pagedResult = await MovieService.GetByDirectorAsync(searchTerm, currentPage, pageSize);
                        break;
                    case "Genre":
                        pagedResult = await MovieService.GetByGenreAsync(searchTerm, currentPage, pageSize);
                        break;
                    case "Title":
                    default:
                        pagedResult = await MovieService.GetByTitleAsync(searchTerm, currentPage, pageSize);
                        break;
                }
            }
        }
        catch (HttpRequestException ex)
        {
            Console.WriteLine($"Network or API error: {ex.Message}");
            errorMessage = "Failed to communicate with the server. Please try again.";
            pagedResult = new PagedResult<MovieDTO> { Items = Enumerable.Empty<MovieDTO>() };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Unexpected error: {ex.Message}");
            errorMessage = "An unexpected error occurred while loading data.";
            pagedResult = new PagedResult<MovieDTO> { Items = Enumerable.Empty<MovieDTO>() };
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        currentPage = 1;
        await FetchData();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ExecuteSearch();
        }
    }

    // --- Pagination Navigation ---

    private async Task GoToPreviousPage()
    {
        if (pagedResult?.HasPrevious == true)
        {
            currentPage--;
            await FetchData();
        }
    }

    private async Task GoToNextPage()
    {
        if (pagedResult?.HasNext == true)
        {
            currentPage++;
            await FetchData();
        }
    }

    // --- Actions ---

    private void AddMovie()
    {
        NavigationManager.NavigateTo("/movies/add");
    }

    private void EditMovie(MovieDTO movie)
    {
        NavigationManager.NavigateTo($"/movies/edit/{movie.Id}");
    }

    private async Task DeleteMovie(MovieDTO movie)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you absolutely sure you want to delete '{movie.Title}'?");

        if (confirmed)
        {
            try
            {
                int modifiedById = 0;

                if (AuthStateTask != null)
                {
                    var authState = await AuthStateTask;
                    var user = authState.User;

                    if (user.Identity is not null && user.Identity.IsAuthenticated)
                    {
                        var userIdString = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                        int.TryParse(userIdString, out modifiedById);
                    }
                }

                await MovieService.DeleteMovieAsync(movie.Id, modifiedById);

                // Reload the current page to reflect the deletion
                await FetchData();
            }
            catch (HttpRequestException ex)
            {
                Console.WriteLine($"API Error deleting movie: {ex.Message}");
                errorMessage = "Failed to delete the movie. Ensure you have the right permissions.";
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting movie: {ex.Message}");
                errorMessage = "An unexpected error occurred during deletion.";
            }
        }
    }
}