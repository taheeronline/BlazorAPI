@page "/books/add"
@rendermode InteractiveServer
@inject IBookService BookService
@inject NavigationManager NavigationManager

<PageTitle>Add New Book</PageTitle>
<div class="container-fluid mt-4">
    <div class="mb-4">  
        <h2><i class="fas fa-book mr-2"></i>Add New Book</h2>
        <p class="text-muted">Enter the details below to add a new book to the library.</p>
    </div>

    <div class="card shadow-sm border-0" style="max-width: 800px;">
        <div class="card-body">
            <!-- Form for adding a new book -->
            <EditForm Model="newBook" OnValidSubmit="HandleValidSubmit" FormName="AddBookForm">
                <DataAnnotationsValidator />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="title" class="form-label fw-bold">Title</label>
                        <InputText id="title" class="form-control" @bind-Value="newBook.Title" placeholder="e.g., The Great Gatsby" />
                        <ValidationMessage For="() => newBook.Title" class="text-danger small" />
                    </div>
                    <div class="col-md-6">
                        <label for="description" class="form-label fw-bold">Description</label>
                        <InputText id="description" class="form-control" @bind-Value="newBook.Description" placeholder="e.g., A classic American novel" />
                        <ValidationMessage For="() => newBook.Description" class="text-danger small" />
                    </div>
                    <div class="col-md-6">
                        <label for="author" class="form-label fw-bold">Author</label>
                        <InputText id="author" class="form-control" @bind-Value="newBook.Author" placeholder="e.g., F. Scott Fitzgerald" />
                        <ValidationMessage For="() => newBook.Author" class="text-danger small" />
                    </div>
                    <div class="col-md-6">
                        <label for="publisher" class="form-label fw-bold">Publisher</label>
                        <InputText id="publisher" class="form-control" @bind-Value="newBook.Publisher" placeholder="e.g., Scribner" />
                        <ValidationMessage For="() => newBook.Publisher" class="text-danger small" />
                    </div>
                    <div class="col-md-6">
                        <label for="price" class="form-label fw-bold">Price</label>
                        <InputNumber id="price" class="form-control" @bind-Value="newBook.Price" step="0.01" min="0" />
                        <ValidationMessage For="() => newBook.Price" class="text-danger small" />
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">
                        <i class="bi bi-save"></i> Save Book
                    </button>
                    <button type="button" class="btn btn-outline-secondary px-4" @onclick="NavigateBack">
                        Cancel
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>


@code{
    // 1. Add the Cascading Parameter to get the user's session data
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }
    private CreateBookDTO newBook = new CreateBookDTO();

    private async Task HandleValidSubmit()
    {
        // 2. Extract the user before sending to the API
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                // Find the ID we stored in CustomAuthStateProvider
                var userIdString = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

                if (int.TryParse(userIdString, out int userId))
                {
                    // 3. Assign the ID to your DTO (ensure your DTO has this property!)
                    newBook.CreatedBy = userId;
                }
            }
        }

        // Call your API service to save the data
        await BookService.CreateBookAsync(newBook);

        // Once saved successfully, redirect back to the book list
        NavigationManager.NavigateTo("/books");
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/books");
    }
}   