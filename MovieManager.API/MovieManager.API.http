# Ensure you update the port number to match your running application's port
@MovieManager.API_HostAddress = http://localhost:5212
@MovieId = 1

### 1. Get all movies
GET {{MovieManager.API_HostAddress}}/api/movies
Accept: application/json

###

### 2. Create a new movie
POST {{MovieManager.API_HostAddress}}/api/movies
Content-Type: application/json
Accept: application/json

{
  "title": "Interstellar",
  "director": "Christopher Nolan",
  "genre": "Sci-Fi",
  "releaseDate": "2014-11-07T00:00:00Z",
  "rating": 8.7
}


### 3. Get a specific movie by ID
GET {{MovieManager.API_HostAddress}}/api/movies/{{MovieId}}
Accept: application/json

###

### 4. Update an existing movie
PUT {{MovieManager.API_HostAddress}}/api/movies/{{MovieId}}
Content-Type: application/json
Accept: application/json

c  vx5

###

### 5. Search movies by title
GET {{MovieManager.API_HostAddress}}/api/movies/search/title/Inception
Accept: application/json

###

### 6. Search movies by director
GET {{MovieManager.API_HostAddress}}/api/movies/search/director/Nolan
Accept: application/json

###

### 7. Search movies by genre
GET {{MovieManager.API_HostAddress}}/api/movies/search/genre/Sci-Fi
Accept: application/json

###

### 8. Delete a movie (Soft Delete)
DELETE {{MovieManager.API_HostAddress}}/api/movies/{{MovieId}}
Accept: */*

###

### 9. Verify deletion (Should return 404 Not Found due to Query Filter)
GET {{MovieManager.API_HostAddress}}/api/movies/{{MovieId}}
Accept: application/json

###